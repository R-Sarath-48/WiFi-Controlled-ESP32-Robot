void drawEye(int offset) {

  display.clearDisplay();
  display.fillCircle(eyeX, eyeY, eyeRadius, SH110X_WHITE);

  int pupilX = eyeX + offset;

  display.fillCircle(pupilX, eyeY, pupilRadius, SH110X_BLACK);
  display.fillCircle(pupilX - 4, eyeY - 4, 3, SH110X_WHITE);26

  display.display();
}

void setup() {

  Serial.begin(115200);

  pinMode(ENA, OUTPUT);
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(ENB, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  Wire.begin(SDA_PIN, SCL_PIN);
  display.begin(0x3C, true);
  display.clearDisplay();

  eyeServo.setPeriodHertz(50);
  eyeServo.attach(SERVO_PIN, 500, 2400);
  eyeServo.write(90);


  WiFi.mode(WIFI_AP);
  WiFi.setSleep(false);          
  WiFi.softAP(ssid, password);
  Serial.println(WiFi.softAPIP());

  server.on("/", handleRoot);
  server.on("/F", [](){ forward(); server.send(200,"text/plain","F"); });
  server.on("/B", [](){ backward(); server.send(200,"text/plain","B"); });
  server.on("/L", [](){ left(); server.send(200,"text/plain","L"); });
  server.on("/R", [](){ right(); server.send(200,"text/plain","R"); });
  server.on("/S", [](){ stopCar(); server.send(200,"text/plain","S"); });

  server.begin();
}

void loop() {

  server.handleClient();   // ALWAYS FIRST

  unsigned long currentMillis = millis();

  if (currentMillis - previousEyeMillis >= eyeInterval) {
    previousEyeMillis = currentMillis;

    pupilOffset += direction;

    if (pupilOffset > 15 || pupilOffset < -15) {
      direction = -direction;
    }

    drawEye(pupilOffset);

    int servoAngle = map(pupilOffset, -15, 15, 60, 120);
    eyeServo.write(servoAngle);
  }
}
